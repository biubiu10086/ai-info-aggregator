# LLM API 配置（兼容 OpenAI 接口的服务均可，如 DeepSeek、小米 MiMo 等）
# 方式1: DeepSeek 官方
# API_KEY=sk-xxx
# API_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-flash

# 方式2: 小米 MiMo
# API_KEY=your_xiaomi_key
# API_BASE_URL=https://your-xiaomi-endpoint/v1
# MODEL_NAME=MiMo

# 方式3: OpenRouter
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# 抓取回溯天数（默认1天，首次运行可设为3）
LOOKBACK_DAYS=1
